<Window x:Class="RevitSheetExporter.UI.SheetSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sheet Exporter — Select Sheets"
        Width="620" Height="560"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">

        <!-- Top toolbar -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">

            <!-- Mode toggle -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Show:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <RadioButton x:Name="RadioSheets" Content="Sheets" IsChecked="True"
                             Margin="0,0,12,0" VerticalAlignment="Center"
                             Checked="ModeChanged"/>
                <RadioButton x:Name="RadioViews" Content="Views"
                             VerticalAlignment="Center"
                             Checked="ModeChanged"/>
            </StackPanel>

            <!-- Filter + search row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="ChkShowInSheetList"
                          Content="Show in sheet list only"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"
                          Checked="FilterChanged"
                          Unchecked="FilterChanged"
                          Grid.Column="0"/>

                <TextBox x:Name="TxtSearch"
                         Grid.Column="1"
                         VerticalAlignment="Center"
                         Padding="4,3"
                         TextChanged="SearchChanged"
                         ToolTip="Filter by sheet number or name">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search…" Foreground="Gray" Margin="5,3"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="2" Content="Select All"
                        Margin="8,0,4,0" Click="SelectAll"/>
                <Button Grid.Column="3" Content="Deselect All"
                        Click="DeselectAll"/>
            </Grid>
        </StackPanel>

        <!-- Bottom buttons -->
        <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0"
                BorderBrush="#DDDDDD" Padding="0,10,0,0" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtSelectionCount"
                           VerticalAlignment="Center"
                           Foreground="#555555"
                           Text="0 selected"/>

                <Button Grid.Column="1" Content="Export…"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="ExportClick"
                        x:Name="BtnExport"
                        IsEnabled="False"/>

                <Button Grid.Column="2" Content="Cancel"
                        IsCancel="True"
                        Click="CancelClick"/>
            </Grid>
        </Border>

        <!-- Sheet list -->
        <ListView x:Name="SheetListView"
                  SelectionMode="Extended"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <GridView>
                    <!-- Checkbox column -->
                    <GridViewColumn Width="36">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          Checked="ItemCheckChanged"
                                          Unchecked="ItemCheckChanged"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                        <GridViewColumn.Header>
                            <CheckBox x:Name="ChkSelectAll"
                                      Click="HeaderCheckBoxClick"
                                      ToolTip="Select / deselect all visible"/>
                        </GridViewColumn.Header>
                    </GridViewColumn>

                    <GridViewColumn Header="Sheet Number" Width="130"
                                    DisplayMemberBinding="{Binding SheetNumber}"/>
                    <GridViewColumn Header="Sheet Name" Width="340"
                                    DisplayMemberBinding="{Binding SheetName}"/>
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</Window>
